{
  "name": "on-writing-code",
  "version": "0.0.0",
  "private": true,
  "description": "Markdown style guides and development principles.",
  "scripts": {
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check \"**/*.md\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0"
  },
  "lint-staged": {
    "*.md": "prettier --write"
  }
}
